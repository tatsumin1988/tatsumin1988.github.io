---
interface Props {
  status: "公開中" | "社内利用" | "試作" | "改善継続中";
  class?: string;
}

const { status, class: className = "" } = Astro.props as Props;

const tones = {
  "公開中": "border-emerald-400/20 bg-emerald-400/10 text-emerald-100",
  "社内利用": "border-sky-400/20 bg-sky-400/10 text-sky-100",
  "試作": "border-amber-400/20 bg-amber-400/10 text-amber-100",
  "改善継続中": "border-violet-400/20 bg-violet-400/10 text-violet-100"
};
---

<span
  class:list={[
    "inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium tracking-[0.08em]",
    tones[status],
    className
  ]}
>
  {status}
</span>
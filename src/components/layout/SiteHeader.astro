---
import Container from "../ui/Container.astro";
import { mainNavigation, siteConfig } from "../../data/site";
import { isActivePath, withBase } from "../../utils/links";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/6 bg-[rgba(9,11,17,0.78)] backdrop-blur-xl">
  <Container class="flex items-center justify-between gap-4 py-4">
    <a href={withBase("/")} class="group inline-flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/4 text-sm font-semibold tracking-[0.24em] text-sky-200 transition duration-200 group-hover:border-sky-300/30 group-hover:bg-sky-400/8">
        DX
      </span>
      <span class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-white">{siteConfig.author.name}</span>
        <span class="text-xs uppercase tracking-[0.2em] text-slate-400">{siteConfig.author.role}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {mainNavigation.map((item) => {
        const active = isActivePath(currentPath, item.href);
        return (
          <a
            href={withBase(item.href)}
            aria-current={active ? "page" : undefined}
            class:list={[
              "rounded-full px-4 py-2 text-sm transition duration-200",
              active
                ? "bg-sky-400/12 text-white ring-1 ring-inset ring-sky-300/20"
                : "text-slate-300 hover:bg-white/6 hover:text-white"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href={withBase(siteConfig.contact.pagePath)}
        class="inline-flex items-center rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200 transition duration-200 hover:border-sky-300/25 hover:bg-sky-400/8 hover:text-white"
      >
        相談する
      </a>
    </div>

    <details class="relative md:hidden">
      <summary class="flex h-11 w-11 list-none items-center justify-center rounded-full border border-white/10 bg-white/4 text-slate-100 marker:hidden [&::-webkit-details-marker]:hidden">
        <span class="sr-only">Open navigation</span>
        <span class="flex flex-col gap-1.5">
          <span class="h-0.5 w-5 rounded-full bg-current"></span>
          <span class="h-0.5 w-5 rounded-full bg-current"></span>
          <span class="h-0.5 w-5 rounded-full bg-current"></span>
        </span>
      </summary>
      <div class="absolute right-0 top-[calc(100%+0.75rem)] w-[min(20rem,calc(100vw-1.5rem))] rounded-3xl border border-white/10 bg-slate-950/96 p-3 shadow-2xl shadow-black/40">
        <nav class="grid gap-1">
          {mainNavigation.map((item) => {
            const active = isActivePath(currentPath, item.href);
            return (
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "rounded-2xl px-4 py-3 text-sm transition duration-200",
                  active
                    ? "bg-sky-400/12 text-white ring-1 ring-inset ring-sky-300/20"
                    : "text-slate-300 hover:bg-white/6 hover:text-white"
                ]}
              >
                {item.label}
              </a>
            );
          })}
          <a
            href={withBase(siteConfig.contact.pagePath)}
            class="mt-2 rounded-2xl border border-white/10 px-4 py-3 text-sm text-slate-200 transition duration-200 hover:border-sky-300/25 hover:bg-sky-400/8 hover:text-white"
          >
            相談する
          </a>
        </nav>
      </div>
    </details>
  </Container>
</header>

---
import Container from "../ui/Container.astro";
import { mainNavigation, siteConfig } from "../../data/site";
import { isActivePath, withBase } from "../../utils/links";

const currentPath = Astro.url.pathname;
const mobileSheetId = "mobile-site-nav";
---

<header class="sticky top-0 z-50 border-b border-white/6 bg-[rgba(9,11,17,0.78)] backdrop-blur-xl">
  <Container class="flex items-center justify-between gap-4 py-4">
    <a href={withBase("/")} class="group inline-flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/4 text-sm font-semibold tracking-[0.24em] text-sky-200 transition duration-200 group-hover:border-sky-300/30 group-hover:bg-sky-400/8">
        DX
      </span>
      <span class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-white">{siteConfig.author.name}</span>
        <span class="text-xs uppercase tracking-[0.2em] text-slate-400">{siteConfig.author.role}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {mainNavigation.map((item) => {
        const active = isActivePath(currentPath, item.href);
        return (
          <a
            href={withBase(item.href)}
            aria-current={active ? "page" : undefined}
            class:list={[
              "rounded-full px-4 py-2 text-sm transition duration-200",
              active
                ? "bg-sky-400/12 text-white ring-1 ring-inset ring-sky-300/20"
                : "text-slate-300 hover:bg-white/6 hover:text-white"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a
        href={withBase(siteConfig.contact.pagePath)}
        class="inline-flex items-center rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200 transition duration-200 hover:border-sky-300/25 hover:bg-sky-400/8 hover:text-white"
      >
        相談する
      </a>
    </div>

    <button
      type="button"
      class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/4 text-slate-100 md:hidden"
      aria-controls={mobileSheetId}
      aria-expanded="false"
      data-mobile-nav-trigger
    >
      <span class="sr-only">メニューを開く</span>
      <span class="flex flex-col gap-1.5">
        <span class="h-0.5 w-5 rounded-full bg-current"></span>
        <span class="h-0.5 w-5 rounded-full bg-current"></span>
        <span class="h-0.5 w-5 rounded-full bg-current"></span>
      </span>
    </button>
  </Container>

  <div id={mobileSheetId} class="mobile-sheet-root md:hidden" data-mobile-sheet-root data-open="false">
    <button type="button" class="mobile-sheet-backdrop" data-mobile-nav-close aria-label="メニューを閉じる"></button>
    <div class="mobile-sheet-panel flex h-full flex-col p-4">
      <div class="flex items-center justify-between gap-4 border-b border-white/8 pb-4">
        <div class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/4 text-sm font-semibold tracking-[0.24em] text-sky-200">
            DX
          </span>
          <div class="leading-tight">
            <p class="text-sm font-semibold text-white">{siteConfig.author.name}</p>
            <p class="mt-1 text-xs tracking-[0.16em] text-slate-400">{siteConfig.author.role}</p>
          </div>
        </div>
        <button
          type="button"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/4 text-slate-200"
          data-mobile-nav-close
        >
          <span class="sr-only">メニューを閉じる</span>
          <span class="text-xl leading-none">×</span>
        </button>
      </div>

      <nav class="mt-6 grid gap-2">
        {mainNavigation.map((item) => {
          const active = isActivePath(currentPath, item.href);
          return (
            <a
              href={withBase(item.href)}
              aria-current={active ? "page" : undefined}
              data-mobile-nav-close
              class:list={[
                "rounded-2xl px-4 py-3 text-base transition duration-200",
                active
                  ? "bg-sky-400/12 text-white ring-1 ring-inset ring-sky-300/20"
                  : "text-slate-300 hover:bg-white/6 hover:text-white"
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="mt-auto space-y-4 border-t border-white/8 pt-5">
        <a
          href={withBase(siteConfig.contact.pagePath)}
          data-mobile-nav-close
          class="inline-flex w-full items-center justify-center rounded-full bg-sky-300 px-5 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
        >
          相談する
        </a>
        <div class="flex flex-wrap gap-2">
          {siteConfig.socialLinks.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center rounded-full border border-white/10 px-4 py-2 text-sm text-slate-300 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    if (!root) return;

    const trigger = root.querySelector("[data-mobile-nav-trigger]");
    const sheet = root.querySelector("[data-mobile-sheet-root]");
    const closeButtons = root.querySelectorAll("[data-mobile-nav-close]");
    if (!(trigger instanceof HTMLButtonElement) || !(sheet instanceof HTMLElement)) return;

    const setOpen = (open) => {
      sheet.dataset.open = open ? "true" : "false";
      trigger.setAttribute("aria-expanded", open ? "true" : "false");
      document.body.dataset.mobileNavOpen = open ? "true" : "false";
    };

    trigger.addEventListener("click", () => {
      setOpen(sheet.dataset.open !== "true");
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => setOpen(false));
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && sheet.dataset.open === "true") {
        setOpen(false);
      }
    });

    window.matchMedia("(min-width: 768px)").addEventListener("change", (event) => {
      if (event.matches) {
        setOpen(false);
      }
    });
  })();
</script>

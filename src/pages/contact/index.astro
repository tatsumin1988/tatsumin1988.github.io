---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { siteConfig } from "../../data/site";
import { withBase } from "../../utils/links";

const formIsConfigured = Boolean(siteConfig.contact.formAction);
const formAction = formIsConfigured ? siteConfig.contact.formAction : undefined;
const contactTopics = [
  "副業・制作相談",
  "現場向け社内ツール",
  "AI活用の運用整理",
  "改善テーマの壁打ち"
];
---

<BaseLayout
  title="Contact"
  description="メールアドレスを公開せず、フォーム経由で制作相談や改善テーマの相談を受け付けるページ。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[1fr_0.42fr] lg:items-end">
      <div class="space-y-5">
        <p class="eyebrow">Contact</p>
        <h1 class="page-title max-w-4xl">メールアドレスを公開せず、相談を受け付ける。</h1>
        <p class="lead-copy max-w-3xl">
          副業向けの公開面として、連絡先はフォームに集約しています。制作相談、業務改善テーマの壁打ち、AI活用の整理などはここから送れます。
        </p>
        <div class="flex flex-wrap gap-2">
          {contactTopics.map((item) => (
            <span class="pill">{item}</span>
          ))}
        </div>
      </div>

      <aside class="surface-panel p-6 md:p-7">
        <div class="space-y-5">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Profiles</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {siteConfig.socialLinks.map((item) => (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noreferrer"
                  class="pill transition duration-200 hover:border-sky-300/25 hover:bg-sky-400/10"
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Form Policy</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">{siteConfig.contact.providerDescription}</p>
            <p class="mt-3 text-sm leading-7 text-slate-400">
              送信基盤は {siteConfig.contact.provider} を想定しています。通知先を Gmail に設定して、メール非公開のまま受信できる構成です。
            </p>
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container>
      <div class="surface-panel p-6 md:p-8">
        {!formIsConfigured && (
          <div class="mb-6 rounded-2xl border border-amber-400/20 bg-amber-400/8 p-4 text-sm leading-7 text-amber-100">
            {siteConfig.contact.setupNote}
          </div>
        )}

        <form action={formAction} method="POST" class="grid gap-5">
          <input type="hidden" name="_subject" value={`${siteConfig.title} への問い合わせ`} />
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="grid gap-5 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-medium text-slate-200">お名前</span>
              <input
                type="text"
                name="name"
                required
                class="rounded-2xl border border-white/10 bg-white/4 px-4 py-3 text-sm text-white outline-none transition duration-200 placeholder:text-slate-500 focus:border-sky-300/30"
                placeholder="開発者ネーム / 会社名でも可"
              />
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-medium text-slate-200">返信先メール</span>
              <input
                type="email"
                name="email"
                required
                class="rounded-2xl border border-white/10 bg-white/4 px-4 py-3 text-sm text-white outline-none transition duration-200 placeholder:text-slate-500 focus:border-sky-300/30"
                placeholder="返信を受け取るメールアドレス"
              />
            </label>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <label class="grid gap-2">
              <span class="text-sm font-medium text-slate-200">相談種別</span>
              <select
                name="topic"
                required
                class="rounded-2xl border border-white/10 bg-[rgb(16,22,34)] px-4 py-3 text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
              >
                <option value="">選択してください</option>
                <option value="副業・制作相談">副業・制作相談</option>
                <option value="社内ツール設計">社内ツール設計</option>
                <option value="AI活用相談">AI活用相談</option>
                <option value="壁打ち・ヒアリング">壁打ち・ヒアリング</option>
              </select>
            </label>

            <label class="grid gap-2">
              <span class="text-sm font-medium text-slate-200">予算感・規模感</span>
              <input
                type="text"
                name="budget"
                class="rounded-2xl border border-white/10 bg-white/4 px-4 py-3 text-sm text-white outline-none transition duration-200 placeholder:text-slate-500 focus:border-sky-300/30"
                placeholder="未定でも可"
              />
            </label>
          </div>

          <label class="grid gap-2">
            <span class="text-sm font-medium text-slate-200">相談内容</span>
            <textarea
              name="message"
              required
              rows="8"
              class="rounded-3xl border border-white/10 bg-white/4 px-4 py-4 text-sm leading-7 text-white outline-none transition duration-200 placeholder:text-slate-500 focus:border-sky-300/30"
              placeholder="現状の課題、困っていること、作りたいもの、相談したい範囲などを自由に書いてください。"
            ></textarea>
          </label>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm leading-7 text-slate-400">
              送信後は {siteConfig.contact.provider} 側で受信され、Gmail 通知へつなぐ想定です。公開面にはメールアドレスを表示しません。
            </p>
            <button
              type="submit"
              disabled={!formIsConfigured}
              class:list={[
                "inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition duration-200",
                formIsConfigured
                  ? "bg-sky-300 text-slate-950 hover:bg-sky-200"
                  : "cursor-not-allowed bg-slate-700 text-slate-300"
              ]}
            >
              {siteConfig.contact.submitLabel}
            </button>
          </div>
        </form>
      </div>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container>
      <div class="surface-panel grid gap-6 p-6 md:grid-cols-[1fr_auto] md:items-end md:p-8">
        <div class="space-y-4">
          <p class="eyebrow">Alternative Paths</p>
          <h2 class="section-title">実績確認は GitHub、依頼導線はココナラに分ける。</h2>
          <p class="lead-copy max-w-3xl">
            技術の見え方は GitHub、相談しやすさはココナラ、一次連絡はフォームに寄せると、副業向けの公開面として整いやすくなります。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          {siteConfig.socialLinks.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-white/10 px-6 py-3 text-sm font-semibold text-white transition duration-200 hover:border-sky-300/20 hover:bg-white/6"
            >
              {item.label}へ
            </a>
          ))}
          <a
            href={withBase("/projects/")}
            class="inline-flex items-center justify-center rounded-full bg-sky-300 px-6 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
          >
            Projectsを見る
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

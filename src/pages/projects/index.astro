---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import StatusBadge from "../../components/ui/StatusBadge.astro";
import { siteConfig } from "../../data/site";
import { collectProjectTechStacks, getPublishedProjects } from "../../utils/content";
import { withBase } from "../../utils/links";

const projects = await getPublishedProjects();
const caseStudies = projects.filter((project) => project.data.project_type === "case_study");
const conceptDemos = projects.filter((project) => project.data.project_type === "concept_demo");
const statuses = [...new Set(caseStudies.map((project) => project.data.status))];
const stacks = collectProjectTechStacks(caseStudies).slice(0, 10);
const featuredProjects = caseStudies.filter((project) => project.data.featured);
const catalogProjects = caseStudies.filter((project) => !project.data.featured);
const statusSummary = statuses.map((status) => ({
  status,
  count: caseStudies.filter((project) => project.data.status === status).length
}));
const leadProject = featuredProjects[0] ?? caseStudies[0];
const sideProjects = (catalogProjects.length > 0 ? catalogProjects : caseStudies).filter((project) => project.id !== leadProject?.id);
const leadCover = leadProject ? withBase(leadProject.data.cover_image ?? "/og/default.svg") : null;
const leadCoverIsSvg = leadCover?.endsWith(".svg");
const primaryProfile = siteConfig.primaryProfile;
---

<BaseLayout
  title="Projects"
  description="製造業DX、AI活用、業務改善の実績と設計事例をまとめたプロジェクト一覧。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div class="space-y-4">
        <p class="eyebrow">実績</p>
        <h1 class="page-title max-w-5xl">現場課題の理解から、運用まで見据えた実装例。</h1>
        <p class="lead-copy max-w-3xl">
          単機能のツール紹介ではなく、現場の入力負荷、確認フロー、責任分界、AI利用時の例外処理まで含めて設計したプロジェクトを掲載しています。
        </p>
      </div>

      <aside class="surface-panel p-6 md:p-7">
        <div class="space-y-5">
            <div>
              <p class="info-label">掲載状況</p>
              <p class="mt-3 text-4xl font-semibold tracking-[-0.04em] text-white">{caseStudies.length}</p>
              <p class="mt-2 text-sm text-slate-400">Case Study数</p>
            </div>
            <div>
              <p class="info-label">状態</p>
              <div class="mt-3 flex flex-wrap gap-3">
                {statusSummary.map((item) => (
                  <div class="flex items-center gap-2">
                  <StatusBadge status={item.status} />
                  <span class="text-xs text-slate-400">{item.count}</span>
                </div>
              ))}
              </div>
            </div>
            <div>
              <p class="info-label">主な技術</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {stacks.map((item) => (
                  <span class="pill">{item.tech} · {item.count}</span>
              ))}
              </div>
            </div>
            <div>
              <p class="info-label">扱う領域</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {siteConfig.domainFocus.map((item) => (
                  <span class="pill">{item}</span>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </Container>
  </section>

  {leadProject && (
    <section class="section-divider section-space pt-10">
      <Container class="space-y-8">
        <div class="max-w-3xl space-y-4">
          <p class="eyebrow eyebrow-muted">代表ケース</p>
          <h2 class="section-title">課題構造と運用設計の両面が見える実績を先に見せる。</h2>
          <p class="lead-copy max-w-3xl">
            一覧の前に、何をどう改善する人なのかが一目で伝わるケースを置いています。詳細ページでは背景、打ち手、効果まで追えます。
          </p>
        </div>
        <a href={withBase(`/projects/${leadProject.id}/`)} class="surface-feature grid overflow-hidden lg:grid-cols-[0.5fr_0.5fr]">
          <div
            class:list={[
              "cover-frame border-b border-white/8 lg:aspect-auto lg:border-b-0 lg:border-r",
              leadCoverIsSvg ? "cover-frame--poster" : "cover-frame--screen"
            ]}
          >
            <img
              src={leadCover!}
              alt={leadProject.data.title}
              class:list={[
                "cover-media",
                leadCoverIsSvg ? "cover-media--poster" : "cover-media--screen"
              ]}
            />
          </div>
          <div class="relative z-10 flex flex-col gap-5 p-6 md:p-8">
            <div class="flex flex-wrap gap-2">
              <StatusBadge status={leadProject.data.status} />
              {leadProject.data.featured && <span class="signal-chip">代表掲載</span>}
            </div>
            <div class="space-y-4">
              <h3 class="text-3xl font-semibold tracking-[-0.04em] text-white">{leadProject.data.title}</h3>
              <p class="text-sm leading-7 text-slate-300">{leadProject.data.summary}</p>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div class="surface-quiet p-4">
                <p class="info-label">対象課題</p>
                <p class="mt-3 text-sm leading-7 text-slate-300">{leadProject.data.problem}</p>
              </div>
              <div class="surface-quiet p-4">
                <p class="info-label">主な打ち手</p>
                <p class="mt-3 text-sm leading-7 text-slate-300">{leadProject.data.solution}</p>
              </div>
            </div>
          </div>
        </a>
      </Container>
    </section>
  )}

  <section class="section-divider section-space pt-10">
    <Container class="space-y-8">
      <div class="grid gap-6 lg:grid-cols-[0.72fr_0.28fr] lg:items-start">
        <div class="space-y-4">
          <p class="eyebrow eyebrow-muted">実績一覧</p>
          <h2 class="section-title">掲載中の全プロジェクト</h2>
          <p class="lead-copy max-w-3xl">
            公開中、試作、改善継続中などステータスの違いを残したまま掲載しています。実務では完成度よりも、どの段階で何を検証しているかが重要だからです。
          </p>
        </div>

        <aside class="surface-panel p-6 md:p-7">
          <div class="space-y-5">
            <div>
              <p class="info-label">見どころ</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                各詳細ページでは、概要だけでなく、課題背景、解決アプローチ、工夫点、効果、関連リンクまで構造化して掲載しています。
              </p>
            </div>
            <div>
              <p class="info-label">外部プロフィール</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                このサイトでは直接連絡を受け付けず、プロフィール確認や依頼導線は外部ページに寄せています。
              </p>
              <a
                href={primaryProfile.href}
                target="_blank"
                rel="noreferrer"
                class="mt-4 inline-flex rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
              >
                {primaryProfile.label}を見る
              </a>
            </div>
          </div>
        </aside>
      </div>

      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {sideProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </Container>
  </section>

  {conceptDemos.length > 0 && (
    <section class="section-divider section-space pt-10">
      <Container class="space-y-8">
        <div class="grid gap-6 lg:grid-cols-[0.72fr_0.28fr] lg:items-start">
          <div class="space-y-4">
            <p class="eyebrow eyebrow-muted">Concept Demos</p>
            <h2 class="section-title">想定業務をもとにした試作UI・ツール。</h2>
            <p class="lead-copy max-w-3xl">
              実案件とは別に、業務課題を想定して設計した試作も載せています。どんなUIやロジックを組めるかを補助的に見せるための枠です。
            </p>
          </div>

          <aside class="surface-panel p-6 md:p-7">
            <div class="space-y-4">
              <p class="info-label">補足</p>
              <p class="text-sm leading-7 text-slate-300">
                ここに載せているものは本番導入実績ではなく、想定業務をもとにした試作です。業務システムのUI設計やロジック実装の方向性を示すために掲載しています。
              </p>
            </div>
          </aside>
        </div>

        <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
          {conceptDemos.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import StatusBadge from "../../components/ui/StatusBadge.astro";
import { siteConfig } from "../../data/site";
import { collectProjectTechStacks, getPublishedProjects } from "../../utils/content";
import { withBase } from "../../utils/links";

const projects = await getPublishedProjects();
const statuses = [...new Set(projects.map((project) => project.data.status))];
const stacks = collectProjectTechStacks(projects).slice(0, 10);
const featuredProjects = projects.filter((project) => project.data.featured);
const catalogProjects = projects.filter((project) => !project.data.featured);
const statusSummary = statuses.map((status) => ({
  status,
  count: projects.filter((project) => project.data.status === status).length
}));
---

<BaseLayout
  title="Projects"
  description="製造業DX、AI活用、業務改善の実績と設計事例をまとめたプロジェクト一覧。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[1fr_0.42fr] lg:items-end">
      <div class="space-y-4">
        <p class="eyebrow">Projects</p>
        <h1 class="page-title max-w-5xl">現場課題の理解から、運用まで見据えた実装例。</h1>
        <p class="lead-copy max-w-3xl">
          単機能のツール紹介ではなく、現場の入力負荷、確認フロー、責任分界、AI利用時の例外処理まで含めて設計したプロジェクトを掲載しています。
        </p>
      </div>

      <aside class="surface-panel p-6 md:p-7">
        <div class="space-y-5">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Overview</p>
            <p class="mt-3 text-4xl font-semibold tracking-[-0.04em] text-white">{projects.length}</p>
            <p class="mt-2 text-sm text-slate-400">掲載プロジェクト数</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Status</p>
            <div class="mt-3 flex flex-wrap gap-3">
              {statusSummary.map((item) => (
                <div class="flex items-center gap-2">
                  <StatusBadge status={item.status} />
                  <span class="text-xs text-slate-400">{item.count}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Tech Stack</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {stacks.map((item) => (
                <span class="pill">{item.tech} · {item.count}</span>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Focus</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {siteConfig.domainFocus.map((item) => (
                <span class="pill">{item}</span>
              ))}
            </div>
          </div>
        </div>
      </aside>
    </Container>
  </section>

  {featuredProjects.length > 0 && (
    <section class="section-divider section-space pt-10">
      <Container class="space-y-8">
        <div class="max-w-3xl space-y-4">
          <p class="eyebrow">Featured</p>
          <h2 class="section-title">課題構造と運用設計の両面が見える代表プロジェクト。</h2>
          <p class="lead-copy max-w-3xl">
            単に機能を実装した例ではなく、入力責任、確認フロー、AI の扱い方まで含めて構造を設計した案件を前面に出しています。
          </p>
        </div>
        <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </Container>
    </section>
  )}

  <section class="section-divider section-space pt-10">
    <Container class="space-y-8">
      <div class="grid gap-6 lg:grid-cols-[0.72fr_0.28fr] lg:items-start">
        <div class="space-y-4">
          <p class="eyebrow">Project Catalog</p>
          <h2 class="section-title">掲載中の全プロジェクト</h2>
          <p class="lead-copy max-w-3xl">
            公開中、試作、改善継続中などステータスの違いを残したまま掲載しています。実務では完成度よりも、どの段階で何を検証しているかが重要だからです。
          </p>
        </div>

        <aside class="surface-panel p-6 md:p-7">
          <div class="space-y-5">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Reading Guide</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                各詳細ページでは、概要だけでなく、課題背景、解決アプローチ、工夫点、効果、関連リンクまで構造化して掲載しています。
              </p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Contact</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">{siteConfig.contactMessage}</p>
              <a
                href={withBase(siteConfig.contact.pagePath)}
                class="mt-4 inline-flex rounded-full border border-white/10 px-4 py-2 text-sm text-slate-200 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
              >
                相談フォームへ
              </a>
            </div>
          </div>
        </aside>
      </div>

      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {(catalogProjects.length > 0 ? catalogProjects : projects).map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>

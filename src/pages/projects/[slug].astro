---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import StatusBadge from "../../components/ui/StatusBadge.astro";
import TagList from "../../components/ui/TagList.astro";
import { getPublishedProjects, getRelatedProjects } from "../../utils/content";
import { withBase } from "../../utils/links";

export async function getStaticPaths() {
  const projects = await getPublishedProjects();
  return projects.map((project) => ({ params: { slug: project.id } }));
}

const projects = await getPublishedProjects();
const slug = Astro.params.slug;
const currentIndex = projects.findIndex((project) => project.id === slug);

if (currentIndex === -1) {
  throw new Error(`Project not found for slug: ${slug}`);
}

const project = projects[currentIndex]!;
const relatedProjects = getRelatedProjects(projects, project, 3);
const { Content, headings } = await render(project);
const coverImage = project.data.cover_image ? withBase(project.data.cover_image) : null;
const coverIsSvg = coverImage?.endsWith(".svg");
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  image={project.data.cover_image ?? "/og/default.svg"}
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div class="space-y-5">
        <p class="eyebrow">実績詳細</p>
        <div class="space-y-4">
          <h1 class="page-title max-w-5xl">{project.data.title}</h1>
          <p class="lead-copy max-w-3xl">{project.data.summary}</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <StatusBadge status={project.data.status} />
          {project.data.featured && (
            <span class="inline-flex items-center rounded-full border border-white/10 px-3 py-1 text-xs font-medium text-slate-200">
              Featured Project
            </span>
          )}
        </div>
        <TagList tags={project.data.tech_stack} />
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="surface-quiet p-5">
          <p class="info-label">この実績の見どころ</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            現場の入力フローと判断フローを分断せず、運用ルールと画面設計を一体で設計した点を中心に整理しています。
          </p>
        </div>
        <div class="surface-quiet p-5">
          <p class="info-label">読む前の目安</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            先に下の概要カードで全体像を掴み、目次から必要なセクションへ移る読み方を想定しています。
          </p>
        </div>
      </div>
    </Container>
  </section>

  {coverImage && (
    <section class="pb-6">
      <Container>
        <div class="surface-panel overflow-hidden">
          <img
            src={coverImage}
            alt={project.data.title}
            class:list={[
              "h-full max-h-[34rem] w-full",
              coverIsSvg ? "bg-slate-950/80 object-contain p-6" : "object-cover"
            ]}
          />
        </div>
      </Container>
    </section>
  )}

  <section class="section-space pt-10">
    <Container class="grid gap-5 lg:grid-cols-3">
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">Overview</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">概要</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">{project.data.summary}</p>
      </article>
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">Problem</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">課題背景</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">{project.data.problem}</p>
      </article>
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">Solution</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">解決アプローチ</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">{project.data.solution}</p>
      </article>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="grid gap-8 lg:grid-cols-3 lg:items-start">
      <article class="surface-panel min-w-0 p-6 md:p-10 lg:col-span-2">
        <div class="prose">
          <Content />
        </div>
      </article>

      <aside class="space-y-6 lg:sticky lg:top-28">
        <div class="surface-panel p-5">
          <div class="space-y-5">
            <p class="info-label">実績情報</p>
            <TableOfContents headings={headings} />
            <div>
              <p class="info-label">状態</p>
              <div class="mt-3">
                <StatusBadge status={project.data.status} />
              </div>
            </div>
            <div>
              <p class="info-label">技術</p>
              <TagList tags={project.data.tech_stack} compact class="mt-3" />
            </div>
            {project.data.links.length > 0 && (
              <div>
                <p class="info-label">関連リンク</p>
                <ul class="mt-3 space-y-2 text-sm text-slate-300">
                  {project.data.links.map((link) => (
                    <li>
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex rounded-xl border border-white/8 px-3 py-2 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </aside>
    </Container>
  </section>

  {relatedProjects.length > 0 && (
    <section class="section-divider section-space pt-10">
      <Container class="space-y-8">
        <div class="space-y-3">
          <p class="eyebrow eyebrow-muted">関連実績</p>
          <h2 class="section-title">近い課題構造のプロジェクト</h2>
        </div>
        <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
          {relatedProjects.map((entry) => <ProjectCard project={entry} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>

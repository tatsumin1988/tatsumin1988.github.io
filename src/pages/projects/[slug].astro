---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import ProjectCard from "../../components/projects/ProjectCard.astro";
import StatusBadge from "../../components/ui/StatusBadge.astro";
import TagList from "../../components/ui/TagList.astro";
import { siteConfig } from "../../data/site";
import { getPublishedProjects, getRelatedProjects } from "../../utils/content";
import { withBase } from "../../utils/links";

export async function getStaticPaths() {
  const projects = await getPublishedProjects();
  return projects.map((project) => ({ params: { slug: project.id } }));
}

const projects = await getPublishedProjects();
const slug = Astro.params.slug;
const currentIndex = projects.findIndex((project) => project.id === slug);

if (currentIndex === -1) {
  throw new Error(`Project not found for slug: ${slug}`);
}

const project = projects[currentIndex]!;
const relatedProjects = getRelatedProjects(projects, project, 3);
const { Content, headings } = await render(project);
const coverImage = project.data.showcase_image
  ? withBase(project.data.showcase_image)
  : project.data.cover_image
    ? withBase(project.data.cover_image)
    : null;
const coverIsSvg = coverImage?.endsWith(".svg");
const primaryProfile = siteConfig.primaryProfile;
const isConceptDemo = project.data.project_type === "concept_demo";
const evidenceMetrics = project.data.evidence_metrics.slice(0, 4);
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  image={project.data.cover_image ?? "/og/default.svg"}
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div class="space-y-5">
        <p class="eyebrow">{isConceptDemo ? "試作デモ" : "実績詳細"}</p>
        <div class="space-y-4">
          <h1 class="page-title max-w-5xl">{project.data.title}</h1>
          <p class="lead-copy max-w-3xl">{project.data.summary}</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          {isConceptDemo && (
            <span class="inline-flex items-center rounded-full border border-sky-300/20 bg-sky-400/10 px-3 py-1 text-xs font-medium text-sky-100">
              想定業務ベースの試作
            </span>
          )}
          <StatusBadge status={project.data.status} />
          {project.data.featured && (
            <span class="inline-flex items-center rounded-full border border-white/10 px-3 py-1 text-xs font-medium text-slate-200">
              代表掲載
            </span>
          )}
          <span
            class:list={[
              "inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium",
              isConceptDemo
                ? "border-sky-300/20 bg-sky-400/10 text-sky-100"
                : "border-emerald-400/20 bg-emerald-400/10 text-emerald-100"
            ]}
          >
            {isConceptDemo ? "試作デモ" : "本番実績"}
          </span>
        </div>
        <TagList tags={project.data.tech_stack} />
        {project.data.demo_url && (
          <div class="flex flex-wrap gap-3 pt-1">
            <a
              href={project.data.demo_url}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-sky-300 px-5 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
            >
              Live Demoを見る
            </a>
          </div>
        )}
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="surface-quiet p-5">
          <p class="info-label">{isConceptDemo ? "この試作の狙い" : "この実績の見どころ"}</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            {isConceptDemo
              ? project.data.disclaimer ?? "想定業務をもとに、UI設計やロジック設計の方向性を示すために作った試作です。"
              : "現場の入力フローと判断フローを分断せず、運用ルールと画面設計を一体で設計した点を中心に整理しています。"}
          </p>
        </div>
        <div class="surface-quiet p-5">
          {isConceptDemo && project.data.audience ? (
            <>
              <p class="info-label">想定利用者</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">{project.data.audience}</p>
            </>
          ) : (
            <>
              <p class="info-label">読む前の目安</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                先に下の概要カードで全体像を掴み、目次から必要なセクションへ移る読み方を想定しています。
              </p>
            </>
          )}
        </div>
        {evidenceMetrics.length > 0 && !isConceptDemo && (
          <div class="surface-quiet p-5 sm:col-span-2">
            <p class="info-label">定量で見えること</p>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
              {evidenceMetrics.map((item) => (
                <div class="metric-tile">
                  <p class="text-xs tracking-[0.14em] text-slate-400">{item.label}</p>
                  <p class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-white">{item.value}</p>
                  {item.note && <p class="mt-2 text-sm leading-6 text-slate-300">{item.note}</p>}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </Container>
  </section>

  {coverImage && (
    <section class="pb-6">
      <Container>
        <div class="surface-panel overflow-hidden">
          <img
            src={coverImage}
            alt={project.data.title}
            class:list={[
              "cover-media max-h-[34rem]",
              coverIsSvg ? "cover-media--poster" : "cover-media--screen"
            ]}
          />
        </div>
        {project.data.showcase_caption && (
          <p class="mt-3 text-sm text-slate-400">{project.data.showcase_caption}</p>
        )}
      </Container>
    </section>
  )}

  <section class="section-space pt-10">
    <Container class="grid gap-5 lg:grid-cols-3">
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">概要</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">概要</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">{project.data.summary}</p>
      </article>
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">{isConceptDemo ? "利用シーン" : "課題背景"}</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">{isConceptDemo ? "想定利用シーン" : "課題背景"}</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">{isConceptDemo ? project.data.audience ?? project.data.problem : project.data.problem}</p>
      </article>
      <article class="surface-card p-6 md:p-7">
        <p class="text-xs uppercase tracking-widest text-slate-500">{isConceptDemo ? "実装力" : "解決アプローチ"}</p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">{isConceptDemo ? "証明したい実装力" : "解決アプローチ"}</h2>
        {isConceptDemo && project.data.proof_points.length > 0 ? (
          <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-300">
            {project.data.proof_points.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-4 text-sm leading-7 text-slate-300">{project.data.solution}</p>
        )}
      </article>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="grid gap-8 lg:grid-cols-3 lg:items-start">
      <article class="surface-panel min-w-0 p-6 md:p-10 lg:col-span-2">
        <div class="prose">
          <Content />
        </div>
      </article>

      <aside class="space-y-6 lg:sticky lg:top-28">
        <div class="surface-panel p-5">
          <div class="space-y-5">
            <p class="info-label">実績情報</p>
            <TableOfContents headings={headings} />
            <div>
              <p class="info-label">状態</p>
              <div class="mt-3">
                <StatusBadge status={project.data.status} />
              </div>
            </div>
            <div>
              <p class="info-label">技術</p>
              <TagList tags={project.data.tech_stack} compact class="mt-3" />
            </div>
            {project.data.demo_url && (
              <div>
                <p class="info-label">デモ</p>
                <a
                  href={project.data.demo_url}
                  target="_blank"
                  rel="noreferrer"
                  class="mt-3 inline-flex rounded-xl border border-white/8 px-3 py-2 text-sm text-slate-200 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
                >
                  Live Demoを見る
                </a>
              </div>
            )}
            {project.data.links.length > 0 && (
              <div>
                <p class="info-label">関連リンク</p>
                <ul class="mt-3 space-y-2 text-sm text-slate-300">
                  {project.data.links.map((link) => (
                    <li>
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex rounded-xl border border-white/8 px-3 py-2 transition duration-200 hover:border-sky-300/20 hover:bg-white/6 hover:text-white"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="space-y-8">
      <div class="grid gap-6 xl:grid-cols-[0.42fr_0.58fr] xl:items-start">
        <aside class="surface-feature p-6 md:p-8">
          <div class="relative z-10 space-y-5">
            <p class="eyebrow eyebrow-muted">次に見る</p>
            <h2 class="section-title">近い課題構造の実績や外部プロフィールを、ここから追えるようにしています。</h2>
            <p class="text-sm leading-7 text-slate-300">
              実績一覧へ戻るだけでなく、似た課題のケースや外部プロフィールへ直接移れるようにしています。比較しながら見ると、設計の違いも追いやすくなります。
            </p>
            <div class="flex flex-col gap-3 sm:flex-row">
              <a
                href={withBase("/projects/")}
                class="inline-flex items-center justify-center rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-white transition duration-200 hover:border-sky-300/20 hover:bg-white/6"
              >
                実績一覧へ
              </a>
              <a
                href={primaryProfile.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center rounded-full bg-sky-300 px-5 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
              >
                {primaryProfile.label}を見る
              </a>
            </div>
          </div>
        </aside>

        <div class="space-y-4">
          <div class="space-y-2">
            <p class="info-label">関連実績</p>
            <p class="text-sm leading-7 text-slate-400">
              似た課題構造を持つプロジェクトを優先して並べています。
            </p>
          </div>
          {relatedProjects.length > 0 ? (
            <div class="grid gap-6 md:grid-cols-2">
              {relatedProjects.map((entry) => <ProjectCard project={entry} />)}
            </div>
          ) : (
            <div class="surface-card p-6 md:p-7">
              <p class="info-label">関連実績</p>
              <p class="mt-3 text-sm leading-7 text-slate-300">
                まだ関連実績の掲載数が少ないため、今後追加していきます。いったんは実績一覧から全体を見られます。
              </p>
            </div>
          )}
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

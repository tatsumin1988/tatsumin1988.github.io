---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import TagList from "../../components/ui/TagList.astro";
import { formatDate } from "../../utils/dates";
import { getPublishedBlogPosts, getRelatedBlogPosts } from "../../utils/content";
import { withBase } from "../../utils/links";
import { slugifyTaxonomyTerm } from "../../utils/taxonomy";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const posts = await getPublishedBlogPosts();
const slug = Astro.params.slug;
const currentIndex = posts.findIndex((post) => post.id === slug);

if (currentIndex === -1) {
  throw new Error(`Blog post not found for slug: ${slug}`);
}

const post = posts[currentIndex]!;
const newerPost = currentIndex > 0 ? posts[currentIndex - 1]! : null;
const olderPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1]! : null;
const relatedPosts = getRelatedBlogPosts(posts, post, 3);
const { Content, headings } = await render(post);
const coverImage = post.data.cover_image ? withBase(post.data.cover_image) : null;
const coverIsSvg = coverImage?.endsWith(".svg");
const leadTag = post.data.tags[0];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover_image ?? "/og/default.svg"}
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div class="space-y-5">
        <p class="eyebrow">記事</p>
        <div class="space-y-4">
          <h1 class="page-title max-w-5xl">{post.data.title}</h1>
          <p class="lead-copy max-w-3xl">{post.data.description}</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          {post.data.updated && (
            <span class="rounded-full border border-white/8 px-3 py-1 text-xs text-slate-300">
              更新 {formatDate(post.data.updated)}
            </span>
          )}
        </div>
        <TagList tags={post.data.tags} hrefPrefix="/blog/tags" />
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="surface-quiet p-5">
          <p class="info-label">この記事の焦点</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            入力責任、例外処理、AI活用の責任分界など、運用で崩れやすい論点を構造化して扱います。
          </p>
        </div>
        <div class="surface-quiet p-5">
          <p class="info-label">読む前の目安</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            見出しごとに論点を切っているので、目次から必要な箇所だけ拾い読みできます。
          </p>
        </div>
      </div>
    </Container>
  </section>

  {coverImage && (
    <section class="pb-6">
      <Container>
        <div class="surface-panel overflow-hidden">
          <img
            src={coverImage}
            alt={post.data.title}
            class:list={[
              "cover-media max-h-[34rem]",
              coverIsSvg ? "cover-media--poster" : "cover-media--screen"
            ]}
          />
        </div>
      </Container>
    </section>
  )}

  <section class="section-space pt-10">
    <Container class="grid gap-8 lg:grid-cols-3 lg:items-start">
      <article class="surface-panel min-w-0 p-6 md:p-10 lg:col-span-2">
        <div class="prose">
          <Content />
        </div>
      </article>

      <div class="space-y-6 lg:sticky lg:top-28">
        <TableOfContents headings={headings} />
        <div class="surface-panel p-5">
          <div class="space-y-4">
            <p class="info-label">記事情報</p>
            <div>
              <p class="info-label">公開日</p>
              <p class="mt-2 text-sm text-slate-200">{formatDate(post.data.date)}</p>
            </div>
            {post.data.updated && (
              <div>
                <p class="info-label">更新日</p>
                <p class="mt-2 text-sm text-slate-200">{formatDate(post.data.updated)}</p>
              </div>
            )}
            <div>
              <p class="info-label">タグ</p>
              <TagList tags={post.data.tags} compact class="mt-3" hrefPrefix="/blog/tags" />
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="grid gap-6 xl:grid-cols-[0.42fr_0.58fr] xl:items-start">
      <aside class="surface-feature p-6 md:p-8">
        <div class="relative z-10 space-y-5">
          <p class="eyebrow eyebrow-muted">次に読む</p>
          <h2 class="section-title">近いテーマの記事や前後の流れを、ここから続けて追えます。</h2>
          <p class="text-sm leading-7 text-slate-300">
            一覧へ戻るより先に、関連する論点や時系列の前後へ移れるように導線をまとめています。拾い読みしたいときはタグ導線も使えます。
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={withBase("/blog/")}
              class="inline-flex items-center justify-center rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-white transition duration-200 hover:border-sky-300/20 hover:bg-white/6"
            >
              記事一覧へ
            </a>
            {leadTag && (
              <a
                href={withBase(`/blog/tags/${slugifyTaxonomyTerm(leadTag)}/`)}
                class="inline-flex items-center justify-center rounded-full bg-sky-300 px-5 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
              >
                {leadTag}の記事を見る
              </a>
            )}
          </div>
        </div>
      </aside>

      <div class="grid gap-5 md:grid-cols-2">
        {newerPost ? (
          <a href={withBase(`/blog/${newerPost.id}/`)} class="surface-card p-6 md:p-7">
            <p class="info-label">新しい記事</p>
            <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">{newerPost.data.title}</h2>
            <p class="mt-3 text-sm text-slate-400">{newerPost.data.description}</p>
          </a>
        ) : (
          <div class="surface-card p-6 md:p-7 opacity-70">
            <p class="info-label">新しい記事</p>
            <p class="mt-3 text-sm text-slate-400">これが最新の記事です。</p>
          </div>
        )}

        {olderPost ? (
          <a href={withBase(`/blog/${olderPost.id}/`)} class="surface-card p-6 md:p-7">
            <p class="info-label">前の記事</p>
            <h2 class="mt-3 text-xl font-semibold tracking-tight text-white">{olderPost.data.title}</h2>
            <p class="mt-3 text-sm text-slate-400">{olderPost.data.description}</p>
          </a>
        ) : (
          <div class="surface-card p-6 md:p-7 opacity-70">
            <p class="info-label">前の記事</p>
            <p class="mt-3 text-sm text-slate-400">まだこれより古い記事はありません。</p>
          </div>
        )}
      </div>
    </Container>
  </section>

  {relatedPosts.length > 0 && (
    <section class="section-divider section-space pt-10">
      <Container class="space-y-8">
        <div class="space-y-3">
          <p class="eyebrow eyebrow-muted">関連記事</p>
          <h2 class="section-title">近い論点の記事</h2>
          <p class="lead-copy max-w-3xl">
            同じタグを共有しているだけでなく、似た課題構造を持つ記事を優先して並べています。
          </p>
        </div>
        <div class="grid gap-6 xl:grid-cols-2">
          {relatedPosts.map((entry) => <BlogCard post={entry} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>

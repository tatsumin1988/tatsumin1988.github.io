---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import TagList from "../../components/ui/TagList.astro";
import { formatCompactDate } from "../../utils/dates";
import { collectBlogTags, getPublishedBlogPosts } from "../../utils/content";
import { withBase } from "../../utils/links";
import { slugifyTaxonomyTerm } from "../../utils/taxonomy";

const posts = await getPublishedBlogPosts();
const tags = collectBlogTags(posts).slice(0, 10);
const featuredPost = posts[0];
const listPosts = posts.slice(1);
---

<BaseLayout
  title="Blog"
  description="製造業DX、AI活用、業務改善の設計メモと実装ノートをまとめた記事一覧。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="space-y-8">
      <div class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
        <div class="space-y-4">
          <p class="eyebrow">ブログ</p>
          <h1 class="page-title max-w-5xl">設計の判断軸と、AI活用を現場実装へつなぐメモ。</h1>
          <p class="lead-copy max-w-3xl">
            ツールの紹介ではなく、現場で運用が止まりやすいポイント、入力設計、AI導入時の責任分界、改善を継続するための記録設計を中心に書いています。
          </p>
        </div>

        {featuredPost && (
          <aside class="surface-feature overflow-hidden">
            <a href={withBase(`/blog/${featuredPost.id}/`)} class="grid h-full lg:grid-cols-[0.52fr_0.48fr]">
              <div class="relative aspect-[4/3] overflow-hidden border-b border-white/8 lg:aspect-auto lg:border-b-0 lg:border-r">
                <img
                  src={withBase(featuredPost.data.cover_image ?? "/og/default.svg")}
                  alt={featuredPost.data.title}
                  class="h-full w-full object-cover"
                />
              </div>
              <div class="relative z-10 flex h-full flex-col gap-5 p-6 md:p-8">
                <div class="flex flex-wrap items-center gap-3 text-xs tracking-[0.14em] text-slate-300">
                  <span class="signal-chip">特集記事</span>
                  <time datetime={featuredPost.data.date.toISOString()}>{formatCompactDate(featuredPost.data.date)}</time>
                </div>
                <div class="space-y-4">
                  <h2 class="text-3xl font-semibold tracking-[-0.04em] text-white">{featuredPost.data.title}</h2>
                  <p class="text-sm leading-7 text-slate-300">{featuredPost.data.description}</p>
                </div>
                <TagList tags={featuredPost.data.tags} compact hrefPrefix="/blog/tags" />
              </div>
            </a>
          </aside>
        )}
      </div>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="grid gap-8 xl:grid-cols-[0.72fr_0.28fr] xl:items-start">
      <div class="space-y-6">
        {listPosts.length > 0 ? listPosts.map((post) => <BlogCard post={post} />) : featuredPost && <BlogCard post={featuredPost} />}
      </div>

      <aside class="space-y-5 xl:sticky xl:top-28">
        <div class="surface-panel p-6 md:p-7">
          <p class="info-label">公開状況</p>
          <p class="mt-3 text-4xl font-semibold tracking-[-0.04em] text-white">{posts.length}</p>
          <p class="mt-2 text-sm text-slate-400">公開記事数</p>
        </div>

        <div class="surface-panel p-6 md:p-7">
          <p class="info-label">よく扱うテーマ</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((item) => (
              <a
                href={withBase(`/blog/tags/${slugifyTaxonomyTerm(item.tag)}/`)}
                class="signal-chip transition duration-200 hover:border-sky-300/25 hover:bg-sky-400/10"
              >
                {item.tag} · {item.count}
              </a>
            ))}
          </div>
        </div>
      </aside>
    </Container>
  </section>
</BaseLayout>

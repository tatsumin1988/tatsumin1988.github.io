---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import { withBase } from "../../utils/links";

const defaults = {
  monthlyJobs: 120,
  currentMinutes: 18,
  futureMinutes: 8,
  hourlyCost: 2400,
  implementationCost: 180000,
  monthlyRunningCost: 30000,
  adoptionRate: 85
};
---

<BaseLayout
  title="ROIシミュレーター"
  description="改善前後の作業時間、件数、人件費から、費用対効果と回収ラインをその場で試算する試作ツール。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
      <div class="space-y-5">
        <p class="eyebrow">Concept Demo</p>
        <h1 class="page-title max-w-4xl">DX導入ROIシミュレーター</h1>
        <p class="lead-copy max-w-3xl">
          改善前後の作業時間、月間件数、人件費、運用費を動かしながら、回収ラインと費用対効果をその場で確認できる試作ツールです。
        </p>
        <div class="surface-quiet p-5">
          <p class="info-label">補足</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">
            本番導入用の業務システムではなく、改善提案や投資判断の会話でロジックの方向性を共有するためのデモです。
          </p>
        </div>
      </div>

      <aside class="surface-feature p-6 md:p-8">
        <div class="relative z-10 space-y-5">
          <p class="info-label">このデモで見せたいこと</p>
          <ul class="space-y-3 text-sm leading-7 text-slate-300">
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
              <span>入力UIを最小限にしつつ、改善投資の判断材料を揃えられること</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
              <span>数値が変わった瞬間に、回収月数や削減額がどう動くかを見せられること</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
              <span>費用対効果を会話の中で扱いやすい粒度に落とし込めること</span>
            </li>
          </ul>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container>
      <div id="roi-demo" class="grid gap-6 xl:grid-cols-[0.44fr_0.56fr]" data-defaults={JSON.stringify(defaults)}>
        <section class="surface-panel p-6 md:p-8">
          <div class="space-y-6">
            <div>
              <p class="info-label">入力条件</p>
              <h2 class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-white">改善前提を調整</h2>
            </div>

            <form class="grid gap-5">
              <label class="grid gap-2">
                <span class="flex items-center justify-between gap-4">
                  <span class="text-sm font-medium text-slate-200">月間の対象件数</span>
                  <input
                    id="monthlyJobsInput"
                    type="number"
                    min="10"
                    max="2000"
                    step="10"
                    value={defaults.monthlyJobs}
                    class="w-28 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                  />
                </span>
                <input id="monthlyJobs" type="range" min="10" max="2000" step="10" value={defaults.monthlyJobs} />
                <div class="flex items-center justify-between text-sm text-slate-400">
                  <span>10件</span>
                  <strong id="monthlyJobsValue" class="text-white">{defaults.monthlyJobs}件</strong>
                  <span>2000件</span>
                </div>
              </label>

              <div class="grid gap-5 md:grid-cols-2">
                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">改善前の1件あたり作業時間</span>
                    <input
                      id="currentMinutesInput"
                      type="number"
                      min="3"
                      max="120"
                      step="1"
                      value={defaults.currentMinutes}
                      class="w-24 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="currentMinutes" type="range" min="3" max="120" step="1" value={defaults.currentMinutes} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>3分</span>
                    <strong id="currentMinutesValue" class="text-white">{defaults.currentMinutes}分</strong>
                    <span>120分</span>
                  </div>
                </label>

                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">改善後の1件あたり作業時間</span>
                    <input
                      id="futureMinutesInput"
                      type="number"
                      min="1"
                      max="60"
                      step="1"
                      value={defaults.futureMinutes}
                      class="w-24 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="futureMinutes" type="range" min="1" max="60" step="1" value={defaults.futureMinutes} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>1分</span>
                    <strong id="futureMinutesValue" class="text-white">{defaults.futureMinutes}分</strong>
                    <span>60分</span>
                  </div>
                </label>
              </div>

              <div class="grid gap-5 md:grid-cols-2">
                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">対象業務の時間単価</span>
                    <input
                      id="hourlyCostInput"
                      type="number"
                      min="1200"
                      max="6000"
                      step="100"
                      value={defaults.hourlyCost}
                      class="w-28 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="hourlyCost" type="range" min="1200" max="6000" step="100" value={defaults.hourlyCost} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>1,200円</span>
                    <strong id="hourlyCostValue" class="text-white">¥{defaults.hourlyCost.toLocaleString("ja-JP")}</strong>
                    <span>6,000円</span>
                  </div>
                </label>

                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">現場への定着率</span>
                    <input
                      id="adoptionRateInput"
                      type="number"
                      min="40"
                      max="100"
                      step="1"
                      value={defaults.adoptionRate}
                      class="w-24 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="adoptionRate" type="range" min="40" max="100" step="1" value={defaults.adoptionRate} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>40%</span>
                    <strong id="adoptionRateValue" class="text-white">{defaults.adoptionRate}%</strong>
                    <span>100%</span>
                  </div>
                </label>
              </div>

              <div class="grid gap-5 md:grid-cols-2">
                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">初期導入費</span>
                    <input
                      id="implementationCostInput"
                      type="number"
                      min="10000"
                      max="5000000"
                      step="10000"
                      value={defaults.implementationCost}
                      class="w-32 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="implementationCost" type="range" min="10000" max="5000000" step="10000" value={defaults.implementationCost} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>1万円</span>
                    <strong id="implementationCostValue" class="text-white">¥{defaults.implementationCost.toLocaleString("ja-JP")}</strong>
                    <span>500万円</span>
                  </div>
                </label>

                <label class="grid gap-2">
                  <span class="flex items-center justify-between gap-4">
                    <span class="text-sm font-medium text-slate-200">月次運用費</span>
                    <input
                      id="monthlyRunningCostInput"
                      type="number"
                      min="0"
                      max="300000"
                      step="5000"
                      value={defaults.monthlyRunningCost}
                      class="w-32 rounded-xl border border-white/10 bg-[rgba(7,11,18,0.84)] px-3 py-2 text-right text-sm text-white outline-none transition duration-200 focus:border-sky-300/30"
                    />
                  </span>
                  <input id="monthlyRunningCost" type="range" min="0" max="300000" step="5000" value={defaults.monthlyRunningCost} />
                  <div class="flex items-center justify-between text-sm text-slate-400">
                    <span>0円</span>
                    <strong id="monthlyRunningCostValue" class="text-white">¥{defaults.monthlyRunningCost.toLocaleString("ja-JP")}</strong>
                    <span>30万円</span>
                  </div>
                </label>
              </div>
            </form>
          </div>
        </section>

        <section class="surface-feature p-6 md:p-8">
          <div class="relative z-10 space-y-6">
            <div>
              <p class="info-label">試算結果</p>
              <h2 class="mt-3 text-2xl font-semibold tracking-[-0.03em] text-white">削減額と回収ライン</h2>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <article class="metric-tile">
                <p class="info-label">月間削減時間</p>
                <p id="savedHours" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-white">0時間</p>
                <p class="mt-2 text-sm text-slate-400">改善前後の差分を定着率で反映した結果です。</p>
              </article>
              <article class="metric-tile">
                <p class="info-label">月間純削減額</p>
                <p id="monthlySavings" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-white">¥0</p>
                <p class="mt-2 text-sm text-slate-400">削減額から月次運用費を引いた値です。</p>
              </article>
              <article class="metric-tile">
                <p class="info-label">回収月数</p>
                <p id="paybackMonths" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-white">-</p>
                <p class="mt-2 text-sm text-slate-400">月間純削減額がプラスのときだけ算出します。</p>
              </article>
              <article class="metric-tile">
                <p class="info-label">3年ROI</p>
                <p id="roiValue" class="mt-3 text-3xl font-semibold tracking-[-0.04em] text-white">0%</p>
                <p class="mt-2 text-sm text-slate-400">36か月の累計で見た費用対効果です。</p>
              </article>
            </div>

            <div class="surface-quiet p-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="info-label">改善前後のコスト比較</p>
                  <p class="mt-2 text-sm leading-7 text-slate-300">
                    改善前の業務コストと、改善後の工数コストに運用費を足した値を並べています。
                  </p>
                </div>
                <div class="text-right text-sm text-slate-400">
                  <div>改善前: <strong id="beforeCostLabel" class="text-slate-200">¥0</strong></div>
                  <div class="mt-2">改善後: <strong id="afterCostLabel" class="text-slate-200">¥0</strong></div>
                </div>
              </div>
              <div class="mt-5 space-y-3">
                <div>
                  <div class="mb-2 flex items-center justify-between text-xs uppercase tracking-[0.14em] text-slate-500">
                    <span>改善前コスト</span>
                    <span id="beforePercent">100%</span>
                  </div>
                  <div class="h-3 overflow-hidden rounded-full bg-slate-900/80">
                    <div id="beforeBar" class="h-full rounded-full bg-slate-500" style="width: 100%"></div>
                  </div>
                </div>
                <div>
                  <div class="mb-2 flex items-center justify-between text-xs uppercase tracking-[0.14em] text-slate-500">
                    <span>改善後コスト</span>
                    <span id="afterPercent">0%</span>
                  </div>
                  <div class="h-3 overflow-hidden rounded-full bg-slate-900/80">
                    <div id="afterBar" class="h-full rounded-full bg-sky-300" style="width: 0%"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="surface-quiet p-5">
              <p class="info-label">読み取りの目安</p>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-300">
                <li class="flex gap-3">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
                  <span>月間純削減額がマイナスなら、運用費や導入費の見直しが先です。</span>
                </li>
                <li class="flex gap-3">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
                  <span>定着率を下げると、現場実装の難しさがどこまで効くかを確認できます。</span>
                </li>
                <li class="flex gap-3">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-sky-300"></span>
                  <span>実案件では、精度前提や対象部門別の工数差を追加して使う想定です。</span>
                </li>
              </ul>
            </div>
          </div>
        </section>
      </div>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container>
      <div class="surface-panel grid gap-6 p-6 md:grid-cols-[1fr_auto] md:items-end md:p-8">
        <div class="space-y-4">
          <p class="eyebrow eyebrow-muted">Related</p>
          <h2 class="section-title">この試作の位置づけを見たあと、実績ベースの案件に戻れます。</h2>
          <p class="lead-copy max-w-3xl">
            このデモは、UIとロジックの見せ方を確認するための軽い試作です。主軸の実績は引き続き実案件ベースの Projects 側にまとめています。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={withBase("/projects/roi-simulator-concept/")}
            class="inline-flex items-center justify-center rounded-full border border-white/10 px-6 py-3 text-sm font-semibold text-white transition duration-200 hover:border-sky-300/20 hover:bg-white/6"
          >
            コンセプト詳細へ
          </a>
          <a
            href={withBase("/projects/")}
            class="inline-flex items-center justify-center rounded-full bg-sky-300 px-6 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
          >
            実績一覧へ
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script is:inline>
    const root = document.getElementById("roi-demo");

    if (root) {
      const defaults = JSON.parse(root.dataset.defaults ?? "{}");
      const state = { ...defaults };

      const formatCurrency = (value) => `¥${Math.round(value).toLocaleString("ja-JP")}`;

      const elements = {
        monthlyJobs: document.getElementById("monthlyJobs"),
        monthlyJobsInput: document.getElementById("monthlyJobsInput"),
        currentMinutes: document.getElementById("currentMinutes"),
        currentMinutesInput: document.getElementById("currentMinutesInput"),
        futureMinutes: document.getElementById("futureMinutes"),
        futureMinutesInput: document.getElementById("futureMinutesInput"),
        hourlyCost: document.getElementById("hourlyCost"),
        hourlyCostInput: document.getElementById("hourlyCostInput"),
        implementationCost: document.getElementById("implementationCost"),
        implementationCostInput: document.getElementById("implementationCostInput"),
        monthlyRunningCost: document.getElementById("monthlyRunningCost"),
        monthlyRunningCostInput: document.getElementById("monthlyRunningCostInput"),
        adoptionRate: document.getElementById("adoptionRate"),
        adoptionRateInput: document.getElementById("adoptionRateInput"),
        monthlyJobsValue: document.getElementById("monthlyJobsValue"),
        currentMinutesValue: document.getElementById("currentMinutesValue"),
        futureMinutesValue: document.getElementById("futureMinutesValue"),
        hourlyCostValue: document.getElementById("hourlyCostValue"),
        implementationCostValue: document.getElementById("implementationCostValue"),
        monthlyRunningCostValue: document.getElementById("monthlyRunningCostValue"),
        adoptionRateValue: document.getElementById("adoptionRateValue"),
        savedHours: document.getElementById("savedHours"),
        monthlySavings: document.getElementById("monthlySavings"),
        paybackMonths: document.getElementById("paybackMonths"),
        roiValue: document.getElementById("roiValue"),
        beforeCostLabel: document.getElementById("beforeCostLabel"),
        afterCostLabel: document.getElementById("afterCostLabel"),
        beforePercent: document.getElementById("beforePercent"),
        afterPercent: document.getElementById("afterPercent"),
        beforeBar: document.getElementById("beforeBar"),
        afterBar: document.getElementById("afterBar")
      };

      const ranges = {
        monthlyJobs: { min: 10, max: 2000, step: 10 },
        currentMinutes: { min: 3, max: 120, step: 1 },
        futureMinutes: { min: 1, max: 60, step: 1 },
        hourlyCost: { min: 1200, max: 6000, step: 100 },
        implementationCost: { min: 10000, max: 5000000, step: 10000 },
        monthlyRunningCost: { min: 0, max: 300000, step: 5000 },
        adoptionRate: { min: 40, max: 100, step: 1 }
      };

      const clampToRange = (key, rawValue) => {
        const range = ranges[key];
        const numericValue = Number(rawValue);
        const safeValue = Number.isFinite(numericValue) ? numericValue : state[key];
        const clamped = Math.min(range.max, Math.max(range.min, safeValue));
        const stepped = Math.round(clamped / range.step) * range.step;
        return Math.min(range.max, Math.max(range.min, stepped));
      };

      const syncControls = () => {
        elements.monthlyJobs.value = String(state.monthlyJobs);
        elements.monthlyJobsInput.value = String(state.monthlyJobs);
        elements.currentMinutes.value = String(state.currentMinutes);
        elements.currentMinutesInput.value = String(state.currentMinutes);
        elements.futureMinutes.value = String(state.futureMinutes);
        elements.futureMinutesInput.value = String(state.futureMinutes);
        elements.hourlyCost.value = String(state.hourlyCost);
        elements.hourlyCostInput.value = String(state.hourlyCost);
        elements.implementationCost.value = String(state.implementationCost);
        elements.implementationCostInput.value = String(state.implementationCost);
        elements.monthlyRunningCost.value = String(state.monthlyRunningCost);
        elements.monthlyRunningCostInput.value = String(state.monthlyRunningCost);
        elements.adoptionRate.value = String(state.adoptionRate);
        elements.adoptionRateInput.value = String(state.adoptionRate);
      };

      const syncValueLabels = () => {
        elements.monthlyJobsValue.textContent = `${state.monthlyJobs}件`;
        elements.currentMinutesValue.textContent = `${state.currentMinutes}分`;
        elements.futureMinutesValue.textContent = `${state.futureMinutes}分`;
        elements.hourlyCostValue.textContent = formatCurrency(state.hourlyCost);
        elements.implementationCostValue.textContent = formatCurrency(state.implementationCost);
        elements.monthlyRunningCostValue.textContent = formatCurrency(state.monthlyRunningCost);
        elements.adoptionRateValue.textContent = `${state.adoptionRate}%`;
      };

      const recalc = () => {
        const effectiveRate = state.adoptionRate / 100;
        const beforeHours = (state.monthlyJobs * state.currentMinutes) / 60;
        const afterHours = (state.monthlyJobs * state.futureMinutes) / 60;
        const actualAfterHours = beforeHours - (beforeHours - afterHours) * effectiveRate;
        const savedHours = Math.max(beforeHours - actualAfterHours, 0);
        const beforeCost = beforeHours * state.hourlyCost;
        const afterCost = actualAfterHours * state.hourlyCost + state.monthlyRunningCost;
        const monthlySavings = beforeCost - afterCost;
        const paybackMonths = monthlySavings > 0 ? state.implementationCost / monthlySavings : null;
        const roi = state.implementationCost > 0
          ? ((monthlySavings * 36 - state.implementationCost) / state.implementationCost) * 100
          : 0;
        const baseCost = Math.max(beforeCost, afterCost, 1);

        elements.savedHours.textContent = `${savedHours.toFixed(1)}時間`;
        elements.monthlySavings.textContent = formatCurrency(monthlySavings);
        elements.monthlySavings.className =
          monthlySavings >= 0
            ? "mt-3 text-3xl font-semibold tracking-[-0.04em] text-emerald-300"
            : "mt-3 text-3xl font-semibold tracking-[-0.04em] text-rose-300";
        elements.paybackMonths.textContent = paybackMonths ? `${paybackMonths.toFixed(1)}か月` : "回収不能";
        elements.roiValue.textContent = `${roi.toFixed(1)}%`;
        elements.roiValue.className =
          roi >= 0
            ? "mt-3 text-3xl font-semibold tracking-[-0.04em] text-white"
            : "mt-3 text-3xl font-semibold tracking-[-0.04em] text-rose-300";

        elements.beforeCostLabel.textContent = formatCurrency(beforeCost);
        elements.afterCostLabel.textContent = formatCurrency(afterCost);
        elements.beforePercent.textContent = `${((beforeCost / baseCost) * 100).toFixed(0)}%`;
        elements.afterPercent.textContent = `${((afterCost / baseCost) * 100).toFixed(0)}%`;
        elements.beforeBar.style.width = `${(beforeCost / baseCost) * 100}%`;
        elements.afterBar.style.width = `${(afterCost / baseCost) * 100}%`;
      };

      const syncRelatedMinutes = () => {
        if (state.futureMinutes > state.currentMinutes) {
          state.futureMinutes = state.currentMinutes;
        }
      };

      const updateState = (key, rawValue) => {
        state[key] = clampToRange(key, rawValue);
        syncRelatedMinutes();
        syncControls();
        syncValueLabels();
        recalc();
      };

      const bindControl = (key) => {
        const rangeElement = elements[key];
        const inputElement = elements[`${key}Input`];

        rangeElement?.addEventListener("input", () => {
          updateState(key, rangeElement.value);
        });

        inputElement?.addEventListener("input", () => {
          updateState(key, inputElement.value);
        });

        inputElement?.addEventListener("blur", () => {
          updateState(key, inputElement.value);
        });
      };

      [
        "monthlyJobs",
        "currentMinutes",
        "futureMinutes",
        "hourlyCost",
        "implementationCost",
        "monthlyRunningCost",
        "adoptionRate"
      ].forEach(bindControl);

      syncControls();
      syncValueLabels();
      recalc();
    }
  </script>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import { aboutSections } from "../data/site";
import { getPublishedBlogPosts, getPublishedProjects } from "../utils/content";
import { withBase } from "../utils/links";

const strengths = [
  "業務フローの可視化",
  "要件整理と画面設計",
  "社内ツールの実装",
  "AIワークフロー設計",
  "入力負荷の削減",
  "改善運用の定着支援"
];

const process = [
  {
    step: "01",
    title: "現場の困りごとを構造化",
    description:
      "要望をそのまま並べず、頻度、責任者、例外、情報の流れに分解して課題の芯を見つけます。"
  },
  {
    step: "02",
    title: "運用とUIを同時に設計",
    description:
      "画面の見た目だけでなく、誰が入力し、どこで確認し、何をもって完了とするかを一緒に定義します。"
  },
  {
    step: "03",
    title: "改善が続く状態まで考える",
    description:
      "導入直後の満足度ではなく、更新のしやすさ、属人化の回避、段階導入のしやすさを重視します。"
  }
];

const toolGroups = [
  {
    title: "設計と実装",
    items: ["Astro", "TypeScript", "Tailwind CSS", "Content Collections", "GitHub Actions"]
  },
  {
    title: "データと業務整理",
    items: ["Supabase", "Markdown運用", "情報設計", "業務フロー整理", "運用設計"]
  },
  {
    title: "AI活用",
    items: ["LLM Workflow", "Prompt Design", "問い合わせ整理", "要約補助", "判断補助UI"]
  }
];

const workingBeliefs = [
  {
    title: "システム導入を目的化しない",
    description:
      "入れること自体に価値はありません。誰が、いつ、どう使い、何をもって運用完了とするかまで設計して初めて効果になります。"
  },
  {
    title: "AIは判断の前工程を圧縮する",
    description:
      "最終判断を丸ごと置き換えるのではなく、整理、要約、補助入力、確認漏れの抽出など、人が責任を持ちやすい位置に置きます。"
  },
  {
    title: "改善を続けられる記録設計を作る",
    description:
      "単発の成功より、次の改善へつながるログが残ることを重視します。入力負荷と再利用性のバランスを崩さない設計を選びます。"
  }
];

const projects = await getPublishedProjects();
const posts = await getPublishedBlogPosts();
const metrics = [
  { value: String(projects.length), label: "掲載中の実績" },
  { value: String(posts.length), label: "公開ノート" },
  { value: "3", label: "主な進め方" }
];
---

<BaseLayout
  title="About"
  description="製造業DX、AI活用、業務改善に向き合う姿勢と得意領域をまとめたページ。"
>
  <section class="section-space pb-14 pt-14 md:pb-20 md:pt-20">
    <Container class="grid gap-10 lg:grid-cols-[0.94fr_1.06fr] lg:gap-14">
      <div class="space-y-6">
        <p class="eyebrow">概要</p>
        <h1 class="page-title max-w-4xl">履歴の羅列ではなく、改善の進め方そのものを伝える。</h1>
        <p class="lead-copy max-w-3xl">
          製造業の現場改善では、システムを入れること自体が価値ではありません。情報の持ち方、入力責任、確認の流れを設計し、現場で扱える単位まで落として初めて改善になります。
        </p>
        <div class="grid gap-3 sm:grid-cols-3">
          {metrics.map((item) => (
            <div class="metric-tile">
              <p class="text-3xl font-semibold tracking-[-0.04em] text-white">{item.value}</p>
              <p class="mt-2 text-sm text-slate-400">{item.label}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="surface-feature p-6 md:p-8">
        <div class="relative z-10 space-y-5">
          <p class="info-label">専門領域</p>
          <div class="flex flex-wrap gap-2">
            {strengths.map((item) => (
              <span class="signal-chip">{item}</span>
            ))}
          </div>
          <div class="surface-quiet p-5">
            <p class="info-label">重視していること</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">
              機能の多さより、入力負荷、運用ルール、継続改善のしやすさを重視します。必要なのは派手さより、現場で止まらない構造です。
            </p>
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section-divider section-space">
    <Container class="space-y-6">
      <div class="max-w-3xl space-y-4">
        <p class="eyebrow eyebrow-muted">向き合う視点</p>
        <h2 class="section-title">何に困っているのかを、入力と運用の構造まで掘り下げる。</h2>
      </div>
      <article class="surface-feature p-6 md:p-8">
        <div class="relative z-10 grid gap-6 lg:grid-cols-[0.4fr_0.6fr] lg:items-start">
          <div>
            <p class="info-label">{aboutSections[0]?.title}</p>
            <h3 class="mt-4 text-3xl font-semibold tracking-[-0.04em] text-white">
              現場の困りごとを、そのまま機能要求に変換しない。
            </h3>
          </div>
          <p class="text-sm leading-8 text-slate-300">{aboutSections[0]?.description}</p>
        </div>
      </article>
      <div class="grid gap-5 lg:grid-cols-2">
        {aboutSections.slice(1).map((section) => (
          <article class="surface-card p-6 md:p-7">
            <div class="space-y-4">
              <p class="info-label">{section.title}</p>
              <h3 class="text-xl font-semibold tracking-[-0.02em] text-white">{section.title}</h3>
              <p class="muted-copy text-sm">{section.description}</p>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-divider section-space">
    <Container class="grid gap-10 lg:grid-cols-[0.36fr_0.64fr] lg:gap-14">
      <div class="space-y-4">
        <p class="eyebrow eyebrow-muted">進め方</p>
        <h2 class="section-title">改善を前に進めるための、実務寄りの進め方。</h2>
        <p class="lead-copy">
          画面やツールの話を先にせず、現場の入力、確認、責任分界を定義してからUIへ落とします。ここを飛ばすと改善は見た目だけで止まります。
        </p>
      </div>

      <div class="space-y-8">
        {process.map((item) => (
          <article class="timeline-step">
            <span class="timeline-node">{item.step}</span>
            <div class="surface-card p-6 md:p-7">
              <p class="info-label">STEP {item.step}</p>
              <h3 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-white">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-300">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-divider section-space">
    <Container class="space-y-8">
      <div class="max-w-3xl space-y-4">
        <p class="eyebrow eyebrow-muted">手段と道具</p>
        <h2 class="section-title">使う技術は目的ではなく、運用を成立させるための手段です。</h2>
      </div>
      <div class="surface-panel divide-y divide-white/8">
        {toolGroups.map((group) => (
          <article class="grid gap-5 p-6 md:grid-cols-[0.28fr_0.72fr] md:p-7">
            <div class="space-y-4">
              <p class="info-label">{group.title}</p>
              <h3 class="text-2xl font-semibold tracking-[-0.03em] text-white">{group.title}</h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="pill">{item}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-divider section-space">
    <Container class="space-y-8">
      <div class="max-w-3xl space-y-4">
        <p class="eyebrow eyebrow-muted">判断軸</p>
        <h2 class="section-title">改善プロジェクトで一貫して守っている判断軸。</h2>
      </div>
      <div class="space-y-4">
        {workingBeliefs.map((item) => (
          <article class="belief-strip p-6 md:p-7">
            <div class="grid gap-4 md:grid-cols-[0.34fr_0.66fr] md:items-start">
              <h3 class="text-2xl font-semibold tracking-[-0.03em] text-white">{item.title}</h3>
              <p class="text-sm leading-7 text-slate-300">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-divider section-space">
    <Container>
      <div class="surface-feature grid gap-6 p-6 md:grid-cols-[1fr_auto] md:items-end md:p-8">
        <div class="space-y-4">
          <p class="eyebrow eyebrow-muted">次に見るページ</p>
          <h2 class="section-title">実際の設計例と、判断軸を書いた記事の両方を見られる構成にしています。</h2>
          <p class="lead-copy max-w-3xl">
            実績とブログを分けているのは、成果物だけでなく、設計時に何を重視しているかまで伝えるためです。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={withBase("/projects/")}
            class="inline-flex items-center justify-center rounded-full bg-sky-300 px-6 py-3 text-sm font-semibold text-slate-950 transition duration-200 hover:bg-sky-200"
          >
            実績を見る
          </a>
          <a
            href={withBase("/blog/")}
            class="inline-flex items-center justify-center rounded-full border border-white/10 px-6 py-3 text-sm font-semibold text-white transition duration-200 hover:border-sky-300/20 hover:bg-white/6"
          >
            ブログを読む
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

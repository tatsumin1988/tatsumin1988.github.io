---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import { siteConfig } from "../data/site";

const sections = [
  {
    title: "取得する情報",
    body:
      "お問い合わせフォームでは、名前、返信先メールアドレス、相談種別、予算感、相談内容など、返信と相談対応に必要な情報を取得します。"
  },
  {
    title: "利用目的",
    body:
      "取得した情報は、お問い合わせへの返信、相談内容の確認、対応可否の判断、必要に応じた継続連絡のために利用します。"
  },
  {
    title: "外部サービス",
    body:
      "お問い合わせフォームの送信には Formspree を利用しています。送信された情報は Formspree を経由して通知され、運営者が内容を確認します。"
  },
  {
    title: "第三者提供",
    body:
      "法令に基づく場合を除き、本人の同意なく取得した個人情報を第三者へ提供しません。"
  },
  {
    title: "開示・訂正・削除",
    body:
      "取得した情報の開示、訂正、削除を希望する場合は、お問い合わせフォームからその旨を連絡してください。確認のうえ対応します。"
  },
  {
    title: "改定",
    body:
      "本ポリシーは必要に応じて更新することがあります。重要な変更がある場合は、このページで最新内容を公開します。"
  }
];
---

<BaseLayout
  title="プライバシーポリシー"
  description="お問い合わせフォームで取得する個人情報の取り扱いをまとめたページ。"
>
  <section class="section-space pb-12 pt-16 md:pb-16">
    <Container class="grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
      <div class="space-y-4">
        <p class="eyebrow">プライバシーポリシー</p>
        <h1 class="page-title max-w-5xl">お問い合わせで取得する情報の扱い方</h1>
        <p class="lead-copy max-w-3xl">
          このサイトでは、問い合わせ対応に必要な範囲で個人情報を取得します。取得した情報は、返信と相談対応のためにのみ利用します。
        </p>
      </div>

      <aside class="surface-panel p-6 md:p-7">
        <div class="space-y-4">
          <p class="info-label">運営者</p>
          <p class="text-xl font-semibold text-white">{siteConfig.author.name}</p>
          <p class="text-sm leading-7 text-slate-300">
            このサイトは副業向けのポートフォリオ兼ブログとして運営しています。連絡先は公開せず、お問い合わせフォーム経由で受け付けます。
          </p>
        </div>
      </aside>
    </Container>
  </section>

  <section class="section-divider section-space pt-10">
    <Container class="space-y-5">
      {sections.map((section) => (
        <article class="surface-card p-6 md:p-7">
          <div class="space-y-4">
            <p class="info-label">{section.title}</p>
            <h2 class="text-2xl font-semibold tracking-[-0.03em] text-white">{section.title}</h2>
            <p class="text-sm leading-7 text-slate-300">{section.body}</p>
          </div>
        </article>
      ))}
    </Container>
  </section>
</BaseLayout>
